# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/black_bean_sprouts?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# MinIO
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="black-bean-sprouts"
MINIO_USE_SSL="false"

# Agent
ENABLE_OPENCLAW_KERNEL=false
ENABLE_PATCH_COMPILER=false
ENABLE_EDITOR_ENGINE_BRIDGE=false
ENABLE_RENDER_DSL=false
USE_BULLMQ_RENDER=false

# LLM Provider
LLM_API_KEY=""
LLM_MODEL=""
LLM_BASE_URL=""

# Auth
JWT_SECRET="change-me-in-production"
