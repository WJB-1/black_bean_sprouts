# ── Server ──
NODE_ENV=development
PORT=4000

# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/black_bean_sprouts

# ── JWT ──
JWT_SECRET=change-me-to-a-random-string-in-production
JWT_EXPIRES_IN=7d

# ── WeChat OAuth (optional for development) ──
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=http://localhost:3000/api/auth/wechat/callback

# ── Redis (for sessions, queues) ──
REDIS_URL=redis://localhost:6379

# ── MinIO (for file storage) ──
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=black-bean-sprouts
