# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/black_bean_sprouts?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# MinIO
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="black-bean-sprouts"
MINIO_USE_SSL="false"

# Agent
ENABLE_OPENCLAW_KERNEL=false
WORKBENCH_PROMPT_PROVIDER="siliconflow-direct"
OPENCLAW_PROJECT_PATH="../reference_projects/openclaw"
OPENCLAW_STATE_DIR=".openclaw-runtime"
OPENCLAW_CONFIG_PATH=".openclaw-runtime/openclaw.json"
OPENCLAW_WORKSPACE_DIR="."
OPENCLAW_PROVIDER="siliconflow"
OPENCLAW_MODEL="siliconflow/Qwen/Qwen2.5-7B-Instruct"
ENABLE_PATCH_COMPILER=false
ENABLE_EDITOR_ENGINE_BRIDGE=false
ENABLE_RENDER_DSL=false
USE_BULLMQ_RENDER=false

# OpenAI / Codex via OpenClaw
# If you want ChatGPT/Codex OAuth, set:
# WORKBENCH_PROMPT_PROVIDER="openclaw"
# OPENCLAW_PROVIDER="openai-codex"
# OPENCLAW_MODEL="openai-codex/gpt-5.4"
#
# If you want OpenAI Platform API via OpenClaw, set:
# WORKBENCH_PROMPT_PROVIDER="openclaw"
# OPENCLAW_PROVIDER="openai"
# OPENCLAW_MODEL="openai/gpt-5.4"
OPENAI_API_KEY=""

# SiliconFlow direct provider
SILICONFLOW_API_KEY=""
SILICONFLOW_BASE_URL="https://api.siliconflow.cn/v1"
SILICONFLOW_MODEL="Qwen/Qwen2.5-7B-Instruct"

# OpenClaw bootstrap compatibility
SILICONFLOW_MODEL_ID="Qwen/Qwen2.5-7B-Instruct"

# Generic LLM bridge
LLM_API_KEY=""
LLM_MODEL=""
LLM_BASE_URL=""

# Auth
JWT_SECRET="change-me-in-production"

# Billing
APP_BASE_URL="http://localhost:3000"
BILLING_PROVIDER="mock"
BILLING_SUCCESS_URL="http://localhost:3000/billing/success?session_id={CHECKOUT_SESSION_ID}"
BILLING_CANCEL_URL="http://localhost:3000/billing/cancel"
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
BILLING_PLANS_JSON=""
