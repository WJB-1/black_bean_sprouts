{
  "name": "@black-bean-sprouts/doc-schema",
  "version": "1.0.0",
  "description": "Document AST schema — the spine of the platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "smoke:patch": "node ./tests/patch-test.mjs",
    "_typecheck": "tsc --noEmit",
    "typecheck": "pnpm run _typecheck",
    "clean": "rimraf dist tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "ajv": "^8.17.0",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
