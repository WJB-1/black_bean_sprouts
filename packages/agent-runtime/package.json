{
  "name": "@black-bean-sprouts/agent-runtime",
  "version": "0.1.0",
  "description": "Agent runtime types — orchestrator, tools, LLM router",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@black-bean-sprouts/doc-schema": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
